{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/start", "destination": "/start.html" },
    { "source": "/fmify-thanks", "destination": "/fmify-thanks.html" },
    { "source": "/careflow", "destination": "/careflow/index.html" },
    { "source": "/careflow/", "destination": "/careflow/index.html" },
    { "source": "/careflow-birmingham", "destination": "/careflow-birmingham.html" },
    { "source": "/careflow-sutton-coldfield", "destination": "/careflow-sutton-coldfield.html" },
    { "source": "/careflow-west-midlands", "destination": "/careflow-west-midlands.html" },
    { "source": "/careflow/:path*", "destination": "/careflow/:path*.html" }
  ]
}
